{
  "name": "@flagify/mcp",
  "version": "0.1.0",
  "description": "Flagify MCP server — manage feature flags from Claude Desktop, Claude Code, Cursor, Zed, Windsurf, and any MCP-capable host.",
  "type": "module",
  "bin": {
    "flagify-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "node --import tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "feature-flags",
    "flagify",
    "claude",
    "cursor",
    "ai-tools"
  ],
  "homepage": "https://www.flagify.dev/integrations/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/flagifyhq/flagify-mcp.git"
  }
}
